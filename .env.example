# Driftwood — environment. Copy to .env.local and fill in. NEVER commit real secrets.

# --- Splunk Cloud over the 443 web REST proxy (no 8089 / no ACS) ---
SPLUNK_URL=https://your-stack.splunkcloud.com
SPLUNK_USER=your_splunk_user
SPLUNK_PASS=
# optional, defaults to en-GB
# SPLUNK_LOCALE=en-GB

# --- Gemini via Vertex AI (the agent's reasoning brain) ---
# Either point at a service-account JSON file on disk...
GOOGLE_APPLICATION_CREDENTIALS=/abs/path/to/vertex-sa.json
# ...or paste the raw JSON (handy for serverless env vars):
# VERTEX_SA_JSON={"type":"service_account", ...}
# VERTEX_PROJECT=rapid-agents-5166
# VERTEX_LOCATION=global
# GEMINI_MODEL=gemini-flash-latest

# --- Indexes (created automatically if missing) ---
# DRIFTWOOD_DEMO_INDEX=driftwood_demo
# DRIFTWOOD_VERDICT_INDEX=driftwood_verdicts
# BASELINE_WINDOW_DAYS=14

# --- Optional Hosted Model seam (Cisco Deep Time Series). If unset, Driftwood uses SPL-native
#     | predict as the honest, real-Splunk-ML fallback. See _NEEDS notes outside the repo. ---
# HOSTED_MODEL_URL=
# HOSTED_MODEL_KEY=
